{
  "name": "tinasaurus",
  "version": "0.0.0",
  "scripts": {
    "docusaurus": "docusaurus",
    "dev": "tinacms dev -c \"docusaurus start\" ",
    "start": "concurrently \"node server.js\" \"docusaurus start\"",
    "build": "docusaurus build",
    "build-local": "tinacms build --local --skip-indexing --skip-cloud-checks && docusaurus build",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids"
    
  },
  "dependencies": {
    "@docusaurus/core": "3.3.2",
    "@docusaurus/preset-classic": "3.3.2",
    "@mdx-js/react": "^3.1.1",
    "@tinacms/cli": "^2.3.1",
    "@tinacms/datalayer": "^2.0.21",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "mongodb": "^7.2.0",
    "mongodb-level": "^0.0.4",
    "prism-react-renderer": "^2.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tinacms": "^3.8.1",
    "tinacms-authjs": "^22.0.1",
    "tinacms-gitprovider-github": "^4.1.8",
    "title": "^3.5.3"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "3.3.2",
    "concurrently": "^9.2.1"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "engines": {
    "node": ">=22.0"
  },
  "resolutions": {
    "webpack": "~5.105.0"
  },
  "overrides": {
    "webpack": "~5.105.0"
  },
  "pnpm": {
    "overrides": {
      "webpack": "~5.105.0"
    }
  }
}
